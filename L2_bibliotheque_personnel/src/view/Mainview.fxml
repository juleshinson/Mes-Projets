<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1154.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MainController">

    <top>
        <VBox>
            <MenuBar BorderPane.alignment="CENTER">
                <menus>
                    <Menu text="Fichier">
                        <items>
                            <MenuItem onAction="#onImport" text="Importer" />
                            <MenuItem onAction="#onExport" text="Exporter" />
                        </items>
                    </Menu>
                    <Menu text="Edition">
                        <items>
                            <MenuItem onAction="#onAdd" text="Ajouter" />
                            <MenuItem onAction="#onDelete" text="Supprimer" />
                        </items>
                    </Menu>
                    <Menu text="Aide">
                        <items>
                            <MenuItem text="About" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>
            <Label text="📚  Gestionnaire de Livres" maxWidth="Infinity" styleClass="titre-app" />
        </VBox>
    </top>

    <left>
        <VBox prefWidth="394.0" spacing="10.0" styleClass="panneau-gauche" BorderPane.alignment="CENTER">
            <children>
                <TextField fx:id="searchField" maxWidth="Infinity" prefHeight="45.0" promptText="🔍  Rechercher un titre ou auteur..." />

                <ComboBox fx:id="sortComboBox" maxWidth="Infinity" prefHeight="45.0" promptText="Trier par..." />

                <ComboBox fx:id="genreComboBox" maxWidth="Infinity" prefHeight="45.0" promptText="Filtrer par genre" />

                <ListView fx:id="booksListView" maxHeight="Infinity" maxWidth="Infinity" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="10.0" style="-fx-padding: 12;"
              BorderPane.alignment="CENTER">
            <children>

                <HBox prefHeight="255.0" spacing="12.0" VBox.vgrow="ALWAYS">
                    <children>
                        <ImageView fx:id="bookImageView" fitHeight="283.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" />

                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <TextField fx:id="titleField"  maxWidth="Infinity" prefHeight="45.0" promptText="Titre" />
                                <TextField fx:id="authorField" maxWidth="Infinity" prefHeight="45.0" promptText="Auteur" />
                                <TextField fx:id="genreField"  maxWidth="Infinity" prefHeight="45.0" promptText="Genre" />
                                <TextField fx:id="yearField"   maxWidth="Infinity" prefHeight="45.0" promptText="Année de publication" />

                                <TextArea fx:id="synopsisField" maxWidth="Infinity" prefHeight="60.0" promptText="Synopsis..." />
                                <HBox spacing="4.0" style="-fx-padding: 4 0 0 0;">
                                    <children>
                                        <Button fx:id="etoile1" onAction="#rate1" prefHeight="50.0" prefWidth="58.0" text="★" styleClass="etoile-btn" />
                                        <Button fx:id="etoile2" onAction="#rate2" prefHeight="50.0" prefWidth="58.0" text="★" styleClass="etoile-btn" />
                                        <Button fx:id="etoile3" onAction="#rate3" prefHeight="50.0" prefWidth="58.0" text="★" styleClass="etoile-btn" />
                                        <Button fx:id="etoile4" onAction="#rate4" prefHeight="50.0" prefWidth="58.0" text="★" styleClass="etoile-btn" />
                                        <Button fx:id="etoile5" onAction="#rate5" prefHeight="50.0" prefWidth="58.0" text="★" styleClass="etoile-btn" />
                                        <CheckBox fx:id="vu" prefHeight="50.0" text="Lu" style="-fx-padding: 0 0 0 10;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <ScrollPane fitToWidth="true" prefWidth="540.0" HBox.hgrow="ALWAYS">
                            <content>
                                <Label fx:id="detailsLabel" styleClass="label-detail" text="Sélectionnez un livre pour voir les détails" wrapText="true" />
                            </content>
                        </ScrollPane>

                        <ScrollPane fitToWidth="true" prefWidth="360.0" HBox.hgrow="ALWAYS">
                            <content>
                                <Label fx:id="synopsisLabel" styleClass="label-detail" wrapText="true" />
                            </content>
                        </ScrollPane>
                    </children>
                </HBox>

                <HBox spacing="10.0">
                    <children>
                        <Button maxWidth="Infinity" onAction="#onEdit" prefHeight="48.0" text="✏️  Editer" HBox.hgrow="ALWAYS">
                            <font><Font size="18.0" /></font>
                        </Button>
                        <Button maxWidth="Infinity" onAction="#onDelete" prefHeight="48.0" text="🗑️  Supprimer" styleClass="button, btn-supprimer" HBox.hgrow="ALWAYS">
                            <font><Font size="18.0" /></font>
                        </Button>
                        <Button maxWidth="Infinity" onAction="#onSuggestion" prefHeight="55.0" text=" Je ne sais pas quoi lire" HBox.hgrow="ALWAYS">
                            <font><Font size="18.0" /></font>
                        </Button>
                    </children>
                </HBox>

                <HBox spacing="10.0">
                    <children>
                        <Button maxWidth="Infinity" onAction="#onAdd" prefHeight="55.0" text="Ajouter" styleClass="button, btn-ajouter" HBox.hgrow="ALWAYS">
                            <font><Font size="18.0" /></font>
                        </Button>
                        <Button maxWidth="Infinity" onAction="#onImport" prefHeight="55.0" text="Importer" HBox.hgrow="ALWAYS">
                            <font><Font size="18.0" /></font>
                        </Button>
                        <Button maxWidth="Infinity" onAction="#onExport" prefHeight="55.0" text="Exporter" HBox.hgrow="ALWAYS">
                            <font><Font size="18.0" /></font>
                        </Button>
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>
